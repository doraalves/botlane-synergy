# Porta do servidor (padrão: 3001)
PORT=3001

# URL do frontend com permissão para acessar a API
# Desenvolvimento: http://localhost:5173
# Produção: https://seu-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Chave da Riot Games API — obter em: https://developer.riotgames.com
# Necessária para funcionalidades avançadas (dados de partida, ranking, etc.)
RGAPI_KEY=RGAPI-xxxx-xxxx-xxxx-xxxx
